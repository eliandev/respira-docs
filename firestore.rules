rules_version = '2';

// Los leads se escriben SOLO desde el servidor con el Admin SDK, que ignora estas
// reglas. Ningún cliente puede leer ni escribir nada. (PRD §11, guardrails de privacidad).
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
