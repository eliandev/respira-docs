# Respira funciona SIN variables (el cálculo es 100% client-side).
# Estas variables solo son necesarias si activás la captura de lead (Paso 6).

# ── Captura de lead (mostrar el formulario del Paso 4) ────
# Poné "on" para renderizar el formulario de contacto. Si queda vacío, el
# formulario NO se muestra y ningún dato sale del navegador (privacidad).
# Para que además se guarde, configurá Firebase y/o el webhook de abajo.
NEXT_PUBLIC_LEAD_CAPTURE=

# ── Firebase (leads, solo servidor) ───────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ── Ecosistema / app ──────────────────────────────────────
N8N_WEBHOOK_URL=              # opcional: dispara el Lead Engine (reto 4)
LEAD_FALLBACK_EMAIL=         # opcional: correo por defecto a n8n si el lead no deja uno (WhatsApp/llamada); si vacío, el registro se manda sin campo email
NEXT_PUBLIC_APP_URL=http://localhost:3000
